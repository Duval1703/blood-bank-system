# Production Environment Configuration
# Copy this to .env and update with your actual values

APP_NAME="Blood Bank Management System"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE  # Generate with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com

# Timezone
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Database Configuration
# PostgreSQL (Railway/Render)
DB_CONNECTION=pgsql
DB_HOST=your-db-host.railway.app
DB_PORT=5432
DB_DATABASE=railway
DB_USERNAME=postgres
DB_PASSWORD=your-secure-password

# OR MySQL (InfinityFree/cPanel)
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=your_database_name
# DB_USERNAME=your_username
# DB_PASSWORD=your_password

# Session & Cache (use database for distributed systems)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

# Queue (use database for simplicity, redis for scale)
QUEUE_CONNECTION=database

# Broadcasting
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error  # production should use 'error' or 'warning'

# Mail Configuration
# Use 'log' for testing, configure SMTP for production
MAIL_MAILER=log

# For production SMTP (Gmail example):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your.email@gmail.com
# MAIL_PASSWORD=your_app_specific_password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME="${APP_NAME}"

# For SendGrid (100 emails/day free):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_api_key
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME="${APP_NAME}"

# Security
BCRYPT_ROUNDS=12

# Vite (Asset URL for CDN - optional)
VITE_APP_NAME="${APP_NAME}"
# ASSET_URL=https://cdn.yourdomain.com

# Redis (if using redis cache/queue)
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# AWS S3 (for file storage - optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file

# Production Optimization (automatically set by deployment)
# These are managed by artisan commands in production
# config:cache, route:cache, view:cache
